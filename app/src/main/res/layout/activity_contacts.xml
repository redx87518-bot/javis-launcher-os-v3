<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/javis_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/javis_surface"
        android:paddingHorizontal="8dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/javis_text_secondary"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contacts"
            android:textColor="@color/javis_text_primary"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FREQUENT"
        android:textColor="@color/javis_red"
        android:textSize="11sp"
        android:letterSpacing="0.2"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_frequent"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:paddingHorizontal="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ALL CONTACTS"
        android:textColor="@color/javis_red"
        android:textSize="11sp"
        android:letterSpacing="0.2"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_all_contacts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>
</LinearLayout>
