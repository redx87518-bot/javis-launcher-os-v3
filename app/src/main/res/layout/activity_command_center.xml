<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/javis_bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="@color/javis_surface">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/javis_text_secondary"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="COMMAND CENTER"
            android:textColor="@color/javis_red"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.2"
            android:layout_marginStart="12dp" />
    </LinearLayout>

    <!-- System Status -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@color/javis_card"
        android:layout_margin="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SYSTEM STATUS"
            android:textColor="@color/javis_text_secondary"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.2"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_ai_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/javis_green"
            android:textSize="13sp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tv_voice_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/javis_green"
            android:textSize="13sp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tv_personality_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/javis_text_primary"
            android:textSize="13sp"/>
    </LinearLayout>

    <!-- Log header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TASK LOG"
        android:textColor="@color/javis_text_secondary"
        android:textSize="10sp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.2"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="4dp"/>

    <!-- Empty state -->
    <TextView
        android:id="@+id/tv_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No tasks logged yet. Use JAVIS to get started."
        android:textColor="@color/javis_text_secondary"
        android:textSize="13sp"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone"/>

    <!-- Log list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_command_log"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="12dp"/>

</LinearLayout>
