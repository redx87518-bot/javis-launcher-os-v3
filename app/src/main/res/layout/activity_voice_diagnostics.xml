<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/javis_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/javis_surface"
        android:paddingHorizontal="8dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/javis_text_secondary"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Voice Diagnostics"
            android:textColor="@color/javis_text_primary"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView android:id="@+id/tv_engine" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/javis_text_primary" android:textSize="14sp" android:paddingVertical="8dp"/>
        <TextView android:id="@+id/tv_status" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/javis_green" android:textSize="14sp" android:paddingVertical="8dp"/>
        <TextView android:id="@+id/tv_online_status" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/javis_text_secondary" android:textSize="14sp" android:paddingVertical="8dp"/>
        <TextView android:id="@+id/tv_offline_status" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/javis_text_secondary" android:textSize="14sp" android:paddingVertical="8dp"/>
        <TextView android:id="@+id/tv_last_error" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/javis_text_secondary" android:textSize="13sp" android:paddingVertical="8dp"/>

        <Button
            android:id="@+id/btn_test_voice"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:text="Test Voice"
            android:backgroundTint="@color/javis_red"
            android:textColor="@color/white"/>
    </LinearLayout>
</LinearLayout>
