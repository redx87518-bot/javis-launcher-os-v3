<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/javis_bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/javis_surface"
        android:paddingHorizontal="8dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/javis_text_secondary"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SETTINGS"
            android:textColor="@color/javis_text_primary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.2"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── AI PROVIDER ─────────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI PROVIDER"
                android:textColor="@color/javis_red"
                android:textSize="11sp"
                android:letterSpacing="0.2"
                android:layout_marginBottom="8dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="@color/javis_card"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <Spinner
                        android:id="@+id/spinner_provider"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_input"
                        android:popupBackground="@color/javis_surface"/>

                    <EditText
                        android:id="@+id/et_api_key"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="API Key"
                        android:inputType="textPassword"
                        android:textColor="@color/javis_text_primary"
                        android:textColorHint="@color/javis_text_secondary"
                        android:background="@drawable/bg_input"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp"/>

                    <EditText
                        android:id="@+id/et_model"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:hint="Model (e.g. llama3-70b-8192)"
                        android:textColor="@color/javis_text_primary"
                        android:textColorHint="@color/javis_text_secondary"
                        android:background="@drawable/bg_input"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp"/>

                    <TextView
                        android:id="@+id/tv_provider_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/javis_green"
                        android:textSize="12sp"/>

                    <Button
                        android:id="@+id/btn_save_provider"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="12dp"
                        android:text="Save Provider"
                        android:backgroundTint="@color/javis_red"
                        android:textColor="@color/white"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── PERSONALITY MODE (V4) ───────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PERSONALITY MODE"
                android:textColor="@color/javis_red"
                android:textSize="11sp"
                android:letterSpacing="0.2"
                android:layout_marginBottom="8dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="@color/javis_card"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tv_personality_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Current: JARVIS"
                        android:textColor="@color/javis_text_secondary"
                        android:textSize="12sp"
                        android:layout_marginBottom="12dp"/>

                    <RadioGroup
                        android:id="@+id/rg_personality"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <RadioButton
                            android:id="@+id/rb_jarvis"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:text="JARVIS — Formal, calm, addresses you as Sir"
                            android:textColor="@color/javis_text_primary"
                            android:textSize="13sp"
                            android:buttonTint="@color/javis_red"
                            android:paddingStart="8dp"
                            android:checked="true"/>

                        <RadioButton
                            android:id="@+id/rb_professional"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:text="Professional — Concise, business-focused"
                            android:textColor="@color/javis_text_primary"
                            android:textSize="13sp"
                            android:buttonTint="@color/javis_red"
                            android:paddingStart="8dp"/>

                        <RadioButton
                            android:id="@+id/rb_friendly"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:text="Friendly — Warm and conversational"
                            android:textColor="@color/javis_text_primary"
                            android:textSize="13sp"
                            android:buttonTint="@color/javis_red"
                            android:paddingStart="8dp"/>
                    </RadioGroup>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── IDENTITY ────────────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="YOUR IDENTITY"
                android:textColor="@color/javis_red"
                android:textSize="11sp"
                android:letterSpacing="0.2"
                android:layout_marginBottom="8dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="@color/javis_card"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tv_current_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Not set"
                        android:textColor="@color/javis_text_secondary"
                        android:textSize="13sp"
                        android:layout_marginBottom="8dp"/>

                    <EditText
                        android:id="@+id/et_user_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Your name"
                        android:textColor="@color/javis_text_primary"
                        android:textColorHint="@color/javis_text_secondary"
                        android:background="@drawable/bg_input"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp"/>

                    <Button
                        android:id="@+id/btn_save_name"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="8dp"
                        android:text="Save Name"
                        android:backgroundTint="@color/javis_surface"
                        android:textColor="@color/javis_text_primary"/>

                    <Button
                        android:id="@+id/btn_clear_memory"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="4dp"
                        android:text="Clear All Memory"
                        android:backgroundTint="@color/javis_surface"
                        android:textColor="@color/javis_red"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── ROUTINE LEARNING (V4) ───────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ROUTINE LEARNING"
                android:textColor="@color/javis_red"
                android:textSize="11sp"
                android:letterSpacing="0.2"
                android:layout_marginBottom="8dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="@color/javis_card"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="JAVIS learns your habits over time to make better suggestions."
                        android:textColor="@color/javis_text_secondary"
                        android:textSize="12sp"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tv_routine_insights"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Keep using JAVIS to build your routine profile."
                        android:textColor="@color/javis_green"
                        android:textSize="13sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── DIAGNOSTICS ─────────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DIAGNOSTICS"
                android:textColor="@color/javis_red"
                android:textSize="11sp"
                android:letterSpacing="0.2"
                android:layout_marginBottom="8dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardBackgroundColor="@color/javis_card"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <Button
                        android:id="@+id/btn_voice_diagnostics"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:text="Voice Diagnostics"
                        android:backgroundTint="@color/javis_surface"
                        android:textColor="@color/javis_text_primary"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
