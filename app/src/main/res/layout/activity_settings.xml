<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/javis_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/javis_surface"
        android:paddingHorizontal="8dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/javis_text_secondary"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textColor="@color/javis_text_primary"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- AI Provider Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI PROVIDER"
                android:textColor="@color/javis_red"
                android:textSize="11sp"
                android:letterSpacing="0.2"
                android:layout_marginBottom="8dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/javis_card"
                app:cardCornerRadius="12dp"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <Spinner
                        android:id="@+id/spinner_provider"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_input"
                        android:popupBackground="@color/javis_surface"/>

                    <EditText
                        android:id="@+id/et_api_key"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="API Key"
                        android:inputType="textPassword"
                        android:textColor="@color/javis_text_primary"
                        android:textColorHint="@color/javis_text_secondary"
                        android:background="@drawable/bg_input"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp"/>

                    <EditText
                        android:id="@+id/et_model"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:hint="Model (e.g. llama3-8b-8192)"
                        android:textColor="@color/javis_text_primary"
                        android:textColorHint="@color/javis_text_secondary"
                        android:background="@drawable/bg_input"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp"/>

                    <TextView
                        android:id="@+id/tv_provider_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/javis_green"
                        android:textSize="12sp"/>

                    <Button
                        android:id="@+id/btn_save_provider"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="12dp"
                        android:text="Save Provider"
                        android:backgroundTint="@color/javis_red"
                        android:textColor="@color/white"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Identity Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="YOUR IDENTITY"
                android:textColor="@color/javis_red"
                android:textSize="11sp"
                android:letterSpacing="0.2"
                android:layout_marginBottom="8dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/javis_card"
                app:cardCornerRadius="12dp"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tv_current_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Not set"
                        android:textColor="@color/javis_text_secondary"
                        android:textSize="13sp"
                        android:layout_marginBottom="8dp"/>

                    <EditText
                        android:id="@+id/et_user_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Your name"
                        android:textColor="@color/javis_text_primary"
                        android:textColorHint="@color/javis_text_secondary"
                        android:background="@drawable/bg_input"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp"/>

                    <Button
                        android:id="@+id/btn_save_name"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="8dp"
                        android:text="Save Name"
                        android:backgroundTint="@color/javis_surface"
                        android:textColor="@color/javis_text_primary"/>

                    <Button
                        android:id="@+id/btn_clear_memory"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="4dp"
                        android:text="Clear All Memory"
                        android:backgroundTint="@color/javis_surface"
                        android:textColor="@color/javis_red"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
